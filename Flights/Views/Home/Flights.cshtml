@{
    ViewData["Title"] = "Flights";
}

<h2>Flights</h2>

<table id="flightsTable" class="table table-bordered table-hover">
    <thead>
        <tr>
            <th>flight number</th>
            <th>direction</th>
            <th>gate number</th>
            <th>people count</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<input type="button" id="show" value="Show"/>
<button class='btn-link js-create' onclick="window.location.replace('/Home/FlightsCreate')">Create</button>

<script>
    $('#show').click(function (e) {
        $.ajax({
            url: '/api/Flights/',
            method: "GET",
            dataType: 'JSON',
            contentType: 'application/json',
            cache: false,
            processData: false,
            success: function (data) {
                console.log(data);
                let table = $('#flightsTable');
                table.find("tbody tr").remove();

                data.forEach(function(flight){
                    table.append("<tr><td>" + 
                    flight.flightNumber + "</td>" +
                    "<td>" + flight.direction + "</td>" +
                    "<td>" + flight.gateNumber + "</td>" +
                    "<td>" + flight.peopleCount + "</td>" + 
                    "<td><button class='btn-link js-edit' data-FlightId=" + flight.flightId + ">Edit</button>&nbsp;<button class='btn-link js-delete' data-FlightId=" + flight.flightId + ">Delete</button></td></tr>");
                });
            },
            error: function(xhr, status, error) {
                alert("Error: " + xhr.status + " | " + xhr.responseText);
                console.log(xhr);
            }
        })
    });

    $("#flightsTable").on("click", ".js-delete", function () {
        var button = $(this);

        //if (confirm("Are you sure you want to delete this author?"))
        {
            $.ajax({
                url: "/api/Flights/" + button.attr("data-FlightId"),
                method: "DELETE",
                success: function () {

                    // получить по кнопке удаляемой строки саму удаляемую строку
                    var row = button[0].parentNode.parentNode;

                    // удалить строку из таблицы
                    row.parentNode.removeChild(row);
                }
            }).fail(function () {
                alert('fail');
            })
        }
    });

    $("#flightsTable").on("click", ".js-edit", function () {
        let button = $(this)
        window.location.href = '/Home/FlightsEdit/' + button.attr("data-FlightId");
    });
</script>