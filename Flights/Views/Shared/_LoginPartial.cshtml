<div id="loggedOut" class="nav navbar-nav navbar-right" onclick="oncl()">LogIn</div>

<dialog id="login" onclick="isClose(event)">
    <div style="display:flex;flex-direction:column; gap: 5px; justify-content: center; align-items: center;">
        <h2 id="bigText">logIn</h2>
        <input type="text" id="username" placeholder="enter username"/>
        <input type="password" id="password" placeholder="enter password" />
        <input type="button" id="loginButton" value="LogIn" />
        <a onclick="switchText()" id="targ">haven`t account? Register</a>
    </div>
</dialog>

<script>

    function oncl(){
        let dialog = document.getElementById('login');
        dialog.showModal();
    }

    function isClose(event){
        let d = document.getElementById('login');
        let dialog = d.getBoundingClientRect();
        let inside = event.clientX >= dialog.left && event.clientX <= dialog.right && event.clientY <= dialog.bottom && event.clientY >= dialog.top;
        if(!inside) d.close();
    }

    function switchText(){
        if($('#loginButton')[0].value == 'LogIn'){
            $('#bigText')[0].innerText = 'Register';
            $('#loginButton')[0].value = 'Register';
            $('#targ')[0].innerText = 'have account? LogIn';
        }
        else{
            $('#bigText')[0].innerText = 'LogIn';
            $('#loginButton')[0].value = 'LogIn';
            $('#targ')[0].innerText = 'haven`t account? Register';
        }
    }

    let tokenKey = "sessionToken";

    $(document).ready(function () {

        // попытка залогиниться
        $('#loginButton').click(function (e) {
            e.preventDefault();

            // объект для залогинивания по токену
            let loginData = {
                grant_type: 'password',
                Username: $('#username').val(),
                Password: $('#password').val()
            };

            $.ajax({
                url: $('#loginButton')[0].value == 'LogIn' ? '/api/Flights/Login' : '/api/Flights/Register',
                method: "POST",
                data: JSON.stringify({
                    grant_type: 'password',
                    Username: $('#username').val(),
                    Password: $('#password').val()
                }),
                dataType: 'JSON',
                contentType: 'application/json',
                success: function (data, textStatus, xhr) {
                    $('#username')[0].value = '';
                    $('#password')[0].value = '';
                    $('#login')[0].close();
                    //console.log(data);

                    // поменять блоки интерфейса
                    $('#userName').text(data.userName);
                    $('#loggedIn').css('display', 'block');
                    $('#loggedOut').css('display', 'none');

                    alert('Login successful!');

                    // сохранить полученный токен и имя пользователя в sessionStorage
                    sessionStorage.setItem(tokenKey, data.access_token);
                    sessionStorage.setItem("userName", data.userName);
                    console.log(data.access_token);
                },
                error: function (xhr, textStatus, errorThrown) {
                    console.log('Login failed!');
                    console.log(xhr);
                }
            });
        });

        $('#logoutButton').click(function (e) {
            e.preventDefault();

            // удаление токена и имени пользователя из sessionStorage
            sessionStorage.removeItem(tokenKey);
            sessionStorage.removeItem("userName");

            // скрыть и показать блоки
            $('#loggedIn').css('display', 'none');
            $('#loggedOut').css('display', 'block');
        });

        //alert("Token key: " + sessionStorage.getItem(tokenKey));

        // проверить, есть ли сохранённый токен пользователя
        if (sessionStorage.getItem(tokenKey) == null) {

            // если нет, то скрыть кнопку выхода
            $('#loggedIn').css('display', 'none');

            // показать блок входа
            $('#loggedOut').css('display', 'block');
        }
        else {

            // если есть, то показать имя пользователя
            $('#userName').text(sessionStorage.getItem("userName"));

            // показать кнопку выхода
            $('#loggedIn').css('display', 'block');

            // скрыть блок входа
            $('#loggedOut').css('display', 'none');
        }
    });
</script>